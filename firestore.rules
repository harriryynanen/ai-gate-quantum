
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check session ownership
    function isSessionOwner(sessionId) {
      return get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
    }

    // Users can only manage their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Sessions are owned by users
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null && isSessionOwner(sessionId);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Recommendations can be read if the user owns the session it belongs to.
    match /recommendations/{recommendationId} {
        allow read: if request.auth != null && exists(/databases/$(database)/documents/sessions/$(get(/databases/$(database)/documents/recommendations/$(recommendationId)).data.sessionId)) && isSessionOwner(get(/databases/$(database)/documents/recommendations/$(recommendationId)).data.sessionId);
        // Deny writes for now, as they are system-generated.
        allow write: if false;
    }

    // Solver inputs are linked to sessions
    match /solverInputs/{solverInputId} {
        allow read: if request.auth != null && exists(/databases/$(database)/documents/sessions/$(get(/databases/$(database)/documents/solverInputs/$(solverInputId)).data.sessionId)) && isSessionOwner(get(/databases/$(database)/documents/solverInputs/$(solverInputId)).data.sessionId);
        allow write: if false; // System-generated
    }

    // Executions are linked to sessions
    match /executions/{executionId} {
        allow read: if request.auth != null && exists(/databases/$(database)/documents/sessions/$(get(/databases/$(database)/documents/executions/$(executionId)).data.sessionId)) && isSessionOwner(get(/databases/$(database)/documents/executions/$(executionId)).data.sessionId);
        allow write: if false; // System-generated
    }

    // Results are linked to executions, which are linked to sessions
    match /results/{resultId} {
      allow read: if request.auth != null &&
                     let executionId = get(/databases/$(database)/documents/results/$(resultId)).data.executionId,
                         sessionId = get(/databases/$(database)/documents/executions/$(executionId)).data.sessionId
                     in isSessionOwner(sessionId);
      allow write: if false; // System-generated
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
